# Codexveil — editor defaults (OSS L1 hygiene)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{ps1,psm1,psd1}]
# Windows scripts often ship CRLF; do not force LF rewrite on edit
end_of_line = crlf
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{jpg,jpeg,png,webp,ico,gif,woff,woff2}]
insert_final_newline = unset
trim_trailing_whitespace = unset
